{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "__elements": {},
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "11.0.0" },
    { "type": "datasource", "id": "prometheus", "name": "Prometheus" },
    { "type": "panel", "id": "timeseries", "name": "Time series" },
    { "type": "panel", "id": "stat", "name": "Stat" },
    { "type": "panel", "id": "table", "name": "Table" },
    { "type": "panel", "id": "barchart", "name": "Bar chart" },
    { "type": "panel", "id": "piechart", "name": "Pie chart" }
  ],
  "id": null,
  "uid": "lis-overview",
  "title": "Lis — AI Assistant",
  "description": "Observability dashboard for the Lis multi-agent AI assistant",
  "tags": ["lis", "ai", "agents"],
  "timezone": "browser",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "refresh": "30s",
  "schemaVersion": 39,
  "time": { "from": "now-6h", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "query": "prometheus",
        "current": {},
        "hide": 0
      }
    ]
  },
  "panels": [
    {
      "type": "row",
      "title": "🎯 Overview",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "collapsed": false
    },
    {
      "type": "stat",
      "title": "Uptime",
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": { "steps": [{ "color": "green", "value": null }] }
        }
      },
      "targets": [
        {
          "expr": "process_runtime_dotnet_process_cpu_time_seconds_total{service_name=\"lis\"}",
          "legendFormat": "uptime"
        }
      ],
      "options": { "reduceOptions": { "calcs": ["last"] } }
    },
    {
      "type": "stat",
      "title": "Memory (Working Set)",
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 536870912 },
              { "color": "red", "value": 1073741824 }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "dotnet_process_memory_working_set{service_name=\"lis\"}"
        }
      ],
      "options": { "reduceOptions": { "calcs": ["last"] } }
    },
    {
      "type": "stat",
      "title": "HTTP Request Rate",
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "thresholds": { "steps": [{ "color": "blue", "value": null }] }
        }
      },
      "targets": [
        {
          "expr": "rate(http_server_request_duration_seconds_count{service_name=\"lis\"}[5m])"
        }
      ],
      "options": { "reduceOptions": { "calcs": ["last"] } }
    },
    {
      "type": "stat",
      "title": "HTTP Error Rate (5xx)",
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 0.01 }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "rate(http_server_request_duration_seconds_count{service_name=\"lis\",http_response_status_code=~\"5..\"}[5m])"
        }
      ],
      "options": { "reduceOptions": { "calcs": ["last"] } }
    },
    {
      "type": "stat",
      "title": "LLM Requests (total)",
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "thresholds": { "steps": [{ "color": "purple", "value": null }] }
        }
      },
      "targets": [
        {
          "expr": "sum(increase(gen_ai_client_operation_duration_seconds_count{service_name=\"lis\"}[24h]))"
        }
      ],
      "options": { "reduceOptions": { "calcs": ["last"] } }
    },
    {
      "type": "stat",
      "title": "LLM Tokens (24h)",
      "gridPos": { "h": 4, "w": 4, "x": 20, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": { "steps": [{ "color": "orange", "value": null }] }
        }
      },
      "targets": [
        {
          "expr": "sum(increase(gen_ai_client_token_usage_total{service_name=\"lis\"}[24h]))"
        }
      ],
      "options": { "reduceOptions": { "calcs": ["last"] } }
    },

    {
      "type": "row",
      "title": "🤖 LLM Performance",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 },
      "collapsed": false
    },
    {
      "type": "timeseries",
      "title": "LLM Request Duration (p50 / p95 / p99)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": { "unit": "s", "custom": { "fillOpacity": 10 } }
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, rate(gen_ai_client_operation_duration_seconds_bucket{service_name=\"lis\"}[5m]))",
          "legendFormat": "p50"
        },
        {
          "expr": "histogram_quantile(0.95, rate(gen_ai_client_operation_duration_seconds_bucket{service_name=\"lis\"}[5m]))",
          "legendFormat": "p95"
        },
        {
          "expr": "histogram_quantile(0.99, rate(gen_ai_client_operation_duration_seconds_bucket{service_name=\"lis\"}[5m]))",
          "legendFormat": "p99"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Token Usage Over Time",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": { "unit": "short", "custom": { "fillOpacity": 20, "stacking": { "mode": "normal" } } }
      },
      "targets": [
        {
          "expr": "sum by (gen_ai_token_type) (increase(gen_ai_client_token_usage_total{service_name=\"lis\"}[5m]))",
          "legendFormat": "{{gen_ai_token_type}}"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "LLM Requests by Model",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 14 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": { "unit": "short", "custom": { "fillOpacity": 15, "stacking": { "mode": "normal" } } }
      },
      "targets": [
        {
          "expr": "sum by (gen_ai_request_model) (increase(gen_ai_client_operation_duration_seconds_count{service_name=\"lis\"}[5m]))",
          "legendFormat": "{{gen_ai_request_model}}"
        }
      ]
    },
    {
      "type": "piechart",
      "title": "Token Distribution by Type (24h)",
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 14 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "sum by (gen_ai_token_type) (increase(gen_ai_client_token_usage_total{service_name=\"lis\"}[24h]))",
          "legendFormat": "{{gen_ai_token_type}}"
        }
      ],
      "options": { "legend": { "placement": "right" } }
    },
    {
      "type": "piechart",
      "title": "Requests by Model (24h)",
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 14 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "sum by (gen_ai_request_model) (increase(gen_ai_client_operation_duration_seconds_count{service_name=\"lis\"}[24h]))",
          "legendFormat": "{{gen_ai_request_model}}"
        }
      ],
      "options": { "legend": { "placement": "right" } }
    },

    {
      "type": "row",
      "title": "📡 Channels & Agents",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 22 },
      "collapsed": false
    },
    {
      "type": "timeseries",
      "title": "Outgoing HTTP Requests (to Mattermost / Telegram APIs)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 23 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": { "unit": "short", "custom": { "fillOpacity": 10 } }
      },
      "targets": [
        {
          "expr": "sum by (server_address) (rate(http_client_request_duration_seconds_count{service_name=\"lis\"}[5m]))",
          "legendFormat": "{{server_address}}"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Outgoing HTTP Latency by Target (p95)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 23 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": { "unit": "s", "custom": { "fillOpacity": 5 } }
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (server_address, le) (rate(http_client_request_duration_seconds_bucket{service_name=\"lis\"}[5m])))",
          "legendFormat": "{{server_address}}"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "HTTP Client Errors",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 31 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": { "unit": "short", "custom": { "fillOpacity": 15, "drawStyle": "bars" } }
      },
      "targets": [
        {
          "expr": "sum by (server_address, http_response_status_code) (increase(http_client_request_duration_seconds_count{service_name=\"lis\",http_response_status_code!~\"2..\"}[5m]))",
          "legendFormat": "{{server_address}} — {{http_response_status_code}}"
        }
      ]
    },

    {
      "type": "row",
      "title": "⚙️ Runtime",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 39 },
      "collapsed": false
    },
    {
      "type": "timeseries",
      "title": "Memory Usage",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 40 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": { "unit": "bytes", "custom": { "fillOpacity": 15 } }
      },
      "targets": [
        {
          "expr": "dotnet_process_memory_working_set{service_name=\"lis\"}",
          "legendFormat": "Working Set"
        },
        {
          "expr": "dotnet_gc_heap_total_allocated_bytes_total{service_name=\"lis\"}",
          "legendFormat": "GC Heap Allocated (total)"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "GC Collections",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 40 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": { "unit": "short", "custom": { "fillOpacity": 10, "stacking": { "mode": "normal" } } }
      },
      "targets": [
        {
          "expr": "rate(dotnet_gc_collections_total{service_name=\"lis\"}[5m])",
          "legendFormat": "Gen {{gc_generation}}"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Thread Pool",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 40 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": { "unit": "short", "custom": { "fillOpacity": 10 } }
      },
      "targets": [
        {
          "expr": "dotnet_thread_pool_thread_count{service_name=\"lis\"}",
          "legendFormat": "Active Threads"
        },
        {
          "expr": "dotnet_thread_pool_queue_length{service_name=\"lis\"}",
          "legendFormat": "Queue Length"
        }
      ]
    }
  ],
  "version": 1
}
