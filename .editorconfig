# Top-most EditorConfig file
root = true

# All files
[*]
charset = utf-8
indent_style = tab
indent_size = 4
tab_width = 4
end_of_line = lf
trim_trailing_whitespace = true
insert_final_newline = true

# C# files
[*.cs]

#### .NET Coding Conventions ####

# Organize usings
dotnet_separate_import_directive_groups = true
dotnet_sort_system_directives_first = true
file_header_template = unset

# this. and Me. preferences (require this.)
dotnet_style_qualification_for_event = true:warning
dotnet_style_qualification_for_field = true:warning
dotnet_style_qualification_for_method = true:warning
dotnet_style_qualification_for_property = true:warning

# Language keywords vs BCL types preferences (use int instead of Int32)
dotnet_style_predefined_type_for_locals_parameters_members = true:suggestion
dotnet_style_predefined_type_for_member_access = true:suggestion

# Parentheses preferences
dotnet_style_parentheses_in_arithmetic_binary_operators = always_for_clarity:suggestion
dotnet_style_parentheses_in_other_binary_operators = always_for_clarity:suggestion
dotnet_style_parentheses_in_other_operators = never_if_unnecessary:silent
dotnet_style_parentheses_in_relational_binary_operators = always_for_clarity:suggestion

# Modifier preferences
dotnet_style_require_accessibility_modifiers = for_non_interface_members:warning

# Expression-level preferences
dotnet_style_coalesce_expression = true:suggestion
dotnet_style_collection_initializer = true:suggestion
dotnet_style_explicit_tuple_names = true:suggestion
dotnet_style_null_propagation = true:suggestion
dotnet_style_object_initializer = true:suggestion
dotnet_style_operator_placement_when_wrapping = beginning_of_line
dotnet_style_prefer_auto_properties = true:suggestion
dotnet_style_prefer_compound_assignment = true:suggestion
dotnet_style_prefer_conditional_expression_over_assignment = true:silent
dotnet_style_prefer_conditional_expression_over_return = true:silent
dotnet_style_prefer_inferred_anonymous_type_member_names = true:suggestion
dotnet_style_prefer_inferred_tuple_names = true:suggestion
dotnet_style_prefer_is_null_check_over_reference_equality_method = true:warning
dotnet_style_prefer_simplified_boolean_expressions = true:suggestion
dotnet_style_prefer_simplified_interpolation = true:suggestion
dotnet_style_namespace_match_folder = true:suggestion

# Field preferences
dotnet_style_readonly_field = true:warning

# Parameter preferences
dotnet_code_quality_unused_parameters = all:suggestion

# Suppression preferences
dotnet_remove_unnecessary_suppression_exclusions = none

# New line preferences
dotnet_style_allow_multiple_blank_lines_experimental = false:warning
dotnet_style_allow_statement_immediately_after_block_experimental = false:suggestion

#### C# Coding Conventions ####

# var preferences (prefer explicit types)
csharp_style_var_elsewhere = false:suggestion
csharp_style_var_for_built_in_types = false:suggestion
csharp_style_var_when_type_is_apparent = false:suggestion

# Expression-bodied members
csharp_style_expression_bodied_accessors = true:silent
csharp_style_expression_bodied_constructors = false:silent
csharp_style_expression_bodied_indexers = true:silent
csharp_style_expression_bodied_lambdas = true:silent
csharp_style_expression_bodied_local_functions = false:silent
csharp_style_expression_bodied_methods = true:silent
csharp_style_expression_bodied_operators = true:silent
csharp_style_expression_bodied_properties = true:silent

# Pattern matching preferences
csharp_style_pattern_matching_over_as_with_null_check = true:suggestion
csharp_style_pattern_matching_over_is_with_cast_check = true:suggestion
csharp_style_prefer_not_pattern = true:suggestion
csharp_style_prefer_pattern_matching = true:suggestion
csharp_style_prefer_switch_expression = true:suggestion
csharp_style_prefer_extended_property_pattern = true:suggestion

# Null-checking preferences
csharp_style_conditional_delegate_call = true:suggestion
csharp_style_prefer_null_check_over_type_check = true:suggestion

# Modifier preferences
csharp_prefer_static_local_function = true:suggestion
csharp_prefer_static_anonymous_function = true:suggestion
csharp_preferred_modifier_order = public,private,protected,internal,static,extern,new,virtual,abstract,sealed,override,readonly,unsafe,volatile,async:warning
csharp_style_prefer_readonly_struct = true:suggestion
csharp_style_prefer_readonly_struct_member = true:suggestion

# Code-block preferences
csharp_prefer_braces = false:suggestion
csharp_prefer_simple_using_statement = true:suggestion
csharp_style_namespace_declarations = file_scoped:warning
csharp_style_prefer_top_level_statements = true:silent
csharp_style_prefer_method_group_conversion = true:suggestion
csharp_style_prefer_primary_constructors = true:suggestion

# Expression-level preferences
csharp_prefer_simple_default_expression = true:suggestion
csharp_style_deconstructed_variable_declaration = true:suggestion
csharp_style_implicit_object_creation_when_type_is_apparent = true:suggestion
csharp_style_inlined_variable_declaration = true:suggestion
csharp_style_prefer_index_operator = true:suggestion
csharp_style_prefer_local_over_anonymous_function = true:suggestion
csharp_style_prefer_range_operator = true:suggestion
csharp_style_prefer_tuple_swap = true:suggestion
csharp_style_prefer_utf8_string_literals = true:suggestion
csharp_style_throw_expression = true:suggestion
csharp_style_unused_value_assignment_preference = discard_variable:suggestion
csharp_style_unused_value_expression_statement_preference = discard_variable:silent

# 'using' directive preferences
csharp_using_directive_placement = outside_namespace:warning

# Experimental/new features
csharp_style_allow_embedded_statements_on_same_line_experimental = true:silent
csharp_style_allow_blank_lines_between_consecutive_braces_experimental = false:suggestion
csharp_style_allow_blank_line_after_colon_in_constructor_initializer_experimental = false:suggestion
csharp_style_allow_blank_line_after_token_in_conditional_expression_experimental = false:suggestion
csharp_style_allow_blank_line_after_token_in_arrow_expression_clause_experimental = false:suggestion

#### C# Formatting Rules ####

# New line preferences
csharp_new_line_before_catch = false
csharp_new_line_before_else = false
csharp_new_line_before_finally = false
csharp_new_line_before_members_in_anonymous_types = true
csharp_new_line_before_members_in_object_initializers = true
csharp_new_line_before_open_brace = none
csharp_new_line_between_query_expression_clauses = true

# Indentation preferences
csharp_indent_block_contents = true
csharp_indent_braces = false
csharp_indent_case_contents = true
csharp_indent_case_contents_when_block = true
csharp_indent_labels = one_less_than_current
csharp_indent_switch_labels = true

# Space preferences
csharp_space_after_cast = false
csharp_space_after_colon_in_inheritance_clause = true
csharp_space_after_comma = true
csharp_space_after_dot = false
csharp_space_after_keywords_in_control_flow_statements = true
csharp_space_after_semicolon_in_for_statement = true
csharp_space_around_binary_operators = before_and_after
csharp_space_around_declaration_statements = false
csharp_space_before_colon_in_inheritance_clause = true
csharp_space_before_comma = false
csharp_space_before_dot = false
csharp_space_before_open_square_brackets = false
csharp_space_before_semicolon_in_for_statement = false
csharp_space_between_empty_square_brackets = false
csharp_space_between_method_call_empty_parameter_list_parentheses = false
csharp_space_between_method_call_name_and_opening_parenthesis = false
csharp_space_between_method_call_parameter_list_parentheses = false
csharp_space_between_method_declaration_empty_parameter_list_parentheses = false
csharp_space_between_method_declaration_name_and_open_parenthesis = false
csharp_space_between_method_declaration_parameter_list_parentheses = false
csharp_space_between_parentheses = false
csharp_space_between_square_brackets = false

# Wrapping preferences
csharp_preserve_single_line_blocks = true
csharp_preserve_single_line_statements = true

#### ReSharper Settings ####

# Alignment settings
resharper_csharp_int_align_fields = true
resharper_csharp_int_align_properties = true
resharper_csharp_int_align_methods = true
resharper_csharp_int_align_parameters = true
resharper_csharp_int_align_variables = true
resharper_csharp_int_align_assignments = true
resharper_csharp_int_align_invocations = true
resharper_csharp_int_align_binary_expressions = true
resharper_csharp_int_align_comments = true
resharper_csharp_int_align_switch_sections = true
resharper_csharp_int_align_switch_expressions = true

# Namespace body style
resharper_namespace_body = file_scoped

#### Naming Conventions ####

# Naming rules
dotnet_naming_rule.interface_should_be_begins_with_i.severity = warning
dotnet_naming_rule.interface_should_be_begins_with_i.symbols = interface
dotnet_naming_rule.interface_should_be_begins_with_i.style = begins_with_i

dotnet_naming_rule.types_should_be_pascal_case.severity = warning
dotnet_naming_rule.types_should_be_pascal_case.symbols = types
dotnet_naming_rule.types_should_be_pascal_case.style = pascal_case

dotnet_naming_rule.non_field_members_should_be_pascal_case.severity = warning
dotnet_naming_rule.non_field_members_should_be_pascal_case.symbols = non_field_members
dotnet_naming_rule.non_field_members_should_be_pascal_case.style = pascal_case

dotnet_naming_rule.constant_fields_should_be_pascal_case.severity = warning
dotnet_naming_rule.constant_fields_should_be_pascal_case.symbols = constant_fields
dotnet_naming_rule.constant_fields_should_be_pascal_case.style = pascal_case

dotnet_naming_rule.private_fields_should_be_camel_case.severity = suggestion
dotnet_naming_rule.private_fields_should_be_camel_case.symbols = private_fields
dotnet_naming_rule.private_fields_should_be_camel_case.style = camel_case

dotnet_naming_rule.local_variables_should_be_camel_case.severity = suggestion
dotnet_naming_rule.local_variables_should_be_camel_case.symbols = local_variables
dotnet_naming_rule.local_variables_should_be_camel_case.style = camel_case

dotnet_naming_rule.parameters_should_be_camel_case.severity = suggestion
dotnet_naming_rule.parameters_should_be_camel_case.symbols = parameters
dotnet_naming_rule.parameters_should_be_camel_case.style = camel_case

# Symbol specifications
dotnet_naming_symbols.interface.applicable_kinds = interface
dotnet_naming_symbols.interface.applicable_accessibilities = public, internal, private, protected, protected_internal, private_protected

dotnet_naming_symbols.types.applicable_kinds = class, struct, interface, enum, delegate
dotnet_naming_symbols.types.applicable_accessibilities = public, internal, private, protected, protected_internal, private_protected

dotnet_naming_symbols.non_field_members.applicable_kinds = property, event, method
dotnet_naming_symbols.non_field_members.applicable_accessibilities = public, internal, private, protected, protected_internal, private_protected

dotnet_naming_symbols.constant_fields.applicable_kinds = field
dotnet_naming_symbols.constant_fields.applicable_accessibilities = public, internal, private, protected, protected_internal, private_protected
dotnet_naming_symbols.constant_fields.required_modifiers = const

dotnet_naming_symbols.private_fields.applicable_kinds = field
dotnet_naming_symbols.private_fields.applicable_accessibilities = private, private_protected

dotnet_naming_symbols.local_variables.applicable_kinds = local

dotnet_naming_symbols.parameters.applicable_kinds = parameter

# Naming styles
dotnet_naming_style.pascal_case.capitalization = pascal_case

dotnet_naming_style.begins_with_i.required_prefix = I
dotnet_naming_style.begins_with_i.capitalization = pascal_case

dotnet_naming_style.camel_case.capitalization = camel_case

#### Analyzers ####

# IDE rules
dotnet_diagnostic.IDE0005.severity = warning        # Remove unnecessary usings
dotnet_diagnostic.IDE0011.severity = suggestion     # Add braces
dotnet_diagnostic.IDE0055.severity = none           # Formatting (handled by ReSharper)
dotnet_diagnostic.IDE0060.severity = suggestion     # Remove unused parameter
dotnet_diagnostic.IDE0305.severity = none           # Collection expression (too aggressive)
dotnet_diagnostic.IDE2000.severity = none           # Multiple blank lines (handled by ReSharper)

# CS rules
dotnet_diagnostic.CS4014.severity = warning         # Async call not awaited
dotnet_diagnostic.CS8600.severity = warning         # Converting null literal or possible null value
dotnet_diagnostic.CS8601.severity = warning         # Possible null reference assignment
dotnet_diagnostic.CS8602.severity = warning         # Dereference of possibly null reference
dotnet_diagnostic.CS8603.severity = warning         # Possible null reference return
dotnet_diagnostic.CS8604.severity = warning         # Possible null reference argument
dotnet_diagnostic.CS8618.severity = warning         # Non-nullable field must contain non-null value
dotnet_diagnostic.CS8625.severity = warning         # Cannot convert null literal to non-nullable reference type

# CA rules (Code Analysis)
dotnet_diagnostic.CA1031.severity = suggestion      # Do not catch general exception types
dotnet_diagnostic.CA1062.severity = none            # Validate arguments of public methods (handled by nullable)
dotnet_diagnostic.CA1303.severity = none            # Do not pass literals as localized parameters
dotnet_diagnostic.CA1304.severity = suggestion      # Specify CultureInfo
dotnet_diagnostic.CA1305.severity = suggestion      # Specify IFormatProvider
dotnet_diagnostic.CA1307.severity = suggestion      # Specify StringComparison for clarity
dotnet_diagnostic.CA1308.severity = suggestion      # Normalize strings to uppercase
dotnet_diagnostic.CA1310.severity = suggestion      # Specify StringComparison for correctness
dotnet_diagnostic.CA1707.severity = warning         # Identifiers should not contain underscores
dotnet_diagnostic.CA1716.severity = suggestion      # Identifiers should not match keywords
dotnet_diagnostic.CA1822.severity = suggestion      # Mark members as static
dotnet_diagnostic.CA1848.severity = none            # Use LoggerMessage delegates (not needed with OpenTelemetry)
dotnet_diagnostic.CA1849.severity = warning         # Call async methods when in async method
dotnet_diagnostic.CA2007.severity = none            # ConfigureAwait (not needed in ASP.NET Core)
dotnet_diagnostic.CA2016.severity = warning         # Forward CancellationToken to methods
dotnet_diagnostic.CA2211.severity = warning         # Non-constant fields should not be visible
dotnet_diagnostic.CA2254.severity = suggestion      # Template should be static expression

# CA rules to suppress (not applicable for this project)
dotnet_diagnostic.CA1710.severity = none            # Rename to end in 'Attribute' (aspect attributes)
dotnet_diagnostic.CA1720.severity = none            # Identifier contains type name
dotnet_diagnostic.CA1725.severity = none            # Parameter name should match base declaration
dotnet_diagnostic.CA1727.severity = suggestion      # Use PascalCase for log placeholders
dotnet_diagnostic.CA1861.severity = none            # Avoid constant arrays (migrations)
dotnet_diagnostic.CA2201.severity = suggestion      # Do not raise reserved exception types

# Meziantou.Analyzer (MA) rules
# Full overlap with existing CA/IDE rules — disable
dotnet_diagnostic.MA0001.severity = none            # StringComparison missing (CA1307/CA1310)
dotnet_diagnostic.MA0005.severity = none            # Use Array.Empty<T>() (CA1825)
dotnet_diagnostic.MA0010.severity = none            # Use AttributeUsageAttribute (CA1018)
dotnet_diagnostic.MA0011.severity = none            # IFormatProvider missing (CA1304/CA1305)
dotnet_diagnostic.MA0012.severity = none            # Reserved exception type (CA2201)
dotnet_diagnostic.MA0015.severity = none            # Parameter name in ArgumentException (CA2208)
dotnet_diagnostic.MA0017.severity = none            # Abstract type public constructors (CA1012)
dotnet_diagnostic.MA0018.severity = none            # Static members on generic types (CA1000)
dotnet_diagnostic.MA0036.severity = none            # Make class static (CA1052)
dotnet_diagnostic.MA0037.severity = none            # Remove empty statement (IDE0035)
dotnet_diagnostic.MA0038.severity = none            # Make method static (CA1822)
dotnet_diagnostic.MA0041.severity = none            # Make property static (CA1822)
dotnet_diagnostic.MA0044.severity = none            # Useless ToString call (IDE0071)
dotnet_diagnostic.MA0046.severity = none            # Use EventHandler<T> (CA1003)
dotnet_diagnostic.MA0047.severity = none            # Declare types in namespaces (IDE0161)
dotnet_diagnostic.MA0056.severity = none            # Overridable members in constructor (CA2214)
dotnet_diagnostic.MA0064.severity = none            # Locking on public instance (CA2002)
dotnet_diagnostic.MA0069.severity = none            # Non-constant static fields visible (CA2211)
dotnet_diagnostic.MA0071.severity = none            # Redundant else (IDE0046)
dotnet_diagnostic.MA0073.severity = none            # Comparison with bool constant (IDE0100)
dotnet_diagnostic.MA0102.severity = none            # Make member readonly (IDE0044)
dotnet_diagnostic.MA0134.severity = none            # Observe async result (CS4014)
dotnet_diagnostic.MA0141.severity = none            # Use 'is not null' (IDE0041)
dotnet_diagnostic.MA0142.severity = none            # Use 'is null' (IDE0041)

# Conflicts with project style — disable
dotnet_diagnostic.MA0004.severity = none            # ConfigureAwait (not needed in ASP.NET Core)
dotnet_diagnostic.MA0007.severity = none            # Trailing comma (conflicts with ReSharper)
dotnet_diagnostic.MA0048.severity = none            # File name must match type name (interface+impl in same file)
dotnet_diagnostic.MA0051.severity = none            # Method too long (noisy with orchestration)
dotnet_diagnostic.MA0057.severity = none            # Class name should end with 'Attribute' (CA1710 disabled)
dotnet_diagnostic.MA0058.severity = none            # Class name should end with 'Exception' (CA1710 disabled)
dotnet_diagnostic.MA0059.severity = none            # Class name should end with 'EventArgs' (CA1710 disabled)

# Blazor rules — not applicable
dotnet_diagnostic.MA0115.severity = none            # Unknown component parameter
dotnet_diagnostic.MA0116.severity = none            # SupplyParameterFromQuery needs [Parameter]
dotnet_diagnostic.MA0117.severity = none            # EditorRequired needs [Parameter]
dotnet_diagnostic.MA0118.severity = none            # JSInvokable must be public
dotnet_diagnostic.MA0119.severity = none            # JSRuntime in OnInitialized
dotnet_diagnostic.MA0120.severity = none            # Use InvokeVoidAsync
dotnet_diagnostic.MA0122.severity = none            # SupplyParameterFromQuery in routable components
dotnet_diagnostic.MA0123.severity = none            # Sequence number must be constant
dotnet_diagnostic.MA0187.severity = none            # Use constructor injection over [Inject]

# Regex — suggestion (nice-to-have, not critical)
dotnet_diagnostic.MA0023.severity = suggestion      # Add RegexOptions.ExplicitCapture

# Security — warning
dotnet_diagnostic.MA0009.severity = warning         # Add regex evaluation timeout (ReDoS)
dotnet_diagnostic.MA0035.severity = warning         # Dangerous threading methods (Thread.Abort)
dotnet_diagnostic.MA0039.severity = warning         # Custom certificate validation
dotnet_diagnostic.MA0153.severity = warning         # Logging data with [DataClassification]
dotnet_diagnostic.MA0161.severity = warning         # UseShellExecute must be explicit
dotnet_diagnostic.MA0163.severity = warning         # UseShellExecute false when redirecting

# Async/threading — warning (biggest gap in current setup)
dotnet_diagnostic.MA0042.severity = warning         # .Result in async method (deadlock)
dotnet_diagnostic.MA0045.severity = warning         # .Wait()/.GetAwaiter().GetResult() in async (deadlock)
dotnet_diagnostic.MA0079.severity = warning         # IAsyncEnumerable without .WithCancellation()
dotnet_diagnostic.MA0080.severity = warning         # CancellationToken via .WithCancellation()
dotnet_diagnostic.MA0100.severity = warning         # Await task before disposing
dotnet_diagnostic.MA0129.severity = warning         # Await task in using statement
dotnet_diagnostic.MA0147.severity = warning         # Async void delegate
dotnet_diagnostic.MA0152.severity = suggestion      # Use Unwrap instead of double await
dotnet_diagnostic.MA0155.severity = warning         # Async void methods
dotnet_diagnostic.MA0158.severity = suggestion      # Use System.Threading.Lock

# Correctness/bug prevention — warning
dotnet_diagnostic.MA0022.severity = warning         # Return Task.FromResult not null
dotnet_diagnostic.MA0027.severity = warning         # throw vs throw ex (stack trace)
dotnet_diagnostic.MA0033.severity = warning         # Instance field with [ThreadStatic]
dotnet_diagnostic.MA0050.severity = warning         # Validate args in iterator methods
dotnet_diagnostic.MA0054.severity = warning         # Embed caught exception as innerException
dotnet_diagnostic.MA0060.severity = warning         # Stream.Read return value not used
dotnet_diagnostic.MA0061.severity = warning         # Override changes default parameter value
dotnet_diagnostic.MA0062.severity = warning         # Non-flags enum marked [Flags]
dotnet_diagnostic.MA0072.severity = warning         # Throw from finally block
dotnet_diagnostic.MA0081.severity = warning         # Override omits params keyword
dotnet_diagnostic.MA0082.severity = warning         # NaN in comparisons (always false)
dotnet_diagnostic.MA0084.severity = warning         # Local variable shadows another symbol
dotnet_diagnostic.MA0085.severity = warning         # Anonymous delegate to unsubscribe event
dotnet_diagnostic.MA0086.severity = warning         # Throw from finalizer
dotnet_diagnostic.MA0091.severity = warning         # Event sender should be 'this'
dotnet_diagnostic.MA0092.severity = warning         # Event sender should be null for static
dotnet_diagnostic.MA0093.severity = warning         # EventArgs should not be null
dotnet_diagnostic.MA0095.severity = warning         # IEquatable<T> must override Equals(object)
dotnet_diagnostic.MA0096.severity = warning         # IComparable<T> should implement IEquatable<T>
dotnet_diagnostic.MA0097.severity = warning         # IComparable<T> should override comparison operators
dotnet_diagnostic.MA0121.severity = suggestion      # Do not overwrite parameter value
dotnet_diagnostic.MA0131.severity = warning         # ThrowIfNull on non-nullable type
dotnet_diagnostic.MA0132.severity = warning         # Implicit DateTime to DateTimeOffset conversion
dotnet_diagnostic.MA0133.severity = warning         # Use DateTimeOffset explicitly
dotnet_diagnostic.MA0140.severity = warning         # Both if/else branches identical
dotnet_diagnostic.MA0143.severity = warning         # Primary constructor params should be readonly
dotnet_diagnostic.MA0172.severity = warning         # Both sides of logical op identical
dotnet_diagnostic.MA0195.severity = warning         # Static field used before initialized
dotnet_diagnostic.MA0201.severity = warning         # Zero-valued flag in HasFlag check
dotnet_diagnostic.MA0202.severity = warning         # Conditional compilation branches identical

# Culture/globalization — suggestion
dotnet_diagnostic.MA0002.severity = suggestion      # Missing IEqualityComparer<string>
dotnet_diagnostic.MA0006.severity = suggestion      # Use String.Equals not == for strings
dotnet_diagnostic.MA0021.severity = suggestion      # Use StringComparer.GetHashCode
dotnet_diagnostic.MA0024.severity = suggestion      # Explicit StringComparer in LINQ
dotnet_diagnostic.MA0074.severity = suggestion      # Implicit culture-sensitive methods
dotnet_diagnostic.MA0075.severity = suggestion      # Implicit culture-sensitive ToString
dotnet_diagnostic.MA0076.severity = suggestion      # Culture-sensitive ToString in interpolation
dotnet_diagnostic.MA0127.severity = suggestion      # String.Equals instead of is pattern
dotnet_diagnostic.MA0193.severity = suggestion      # Use MidpointRounding argument

# Performance — suggestion
dotnet_diagnostic.MA0020.severity = suggestion      # Direct methods instead of LINQ
dotnet_diagnostic.MA0028.severity = suggestion      # Optimize StringBuilder
dotnet_diagnostic.MA0029.severity = suggestion      # Combine LINQ methods
dotnet_diagnostic.MA0030.severity = warning         # Useless OrderBy call (likely a bug)
dotnet_diagnostic.MA0031.severity = suggestion      # Optimize Count() usage
dotnet_diagnostic.MA0063.severity = suggestion      # Where before OrderBy
dotnet_diagnostic.MA0078.severity = suggestion      # Use Cast instead of Select to cast
dotnet_diagnostic.MA0089.severity = suggestion      # Optimize string method usage
dotnet_diagnostic.MA0098.severity = suggestion      # Use indexer instead of LINQ
dotnet_diagnostic.MA0105.severity = suggestion      # Avoid closure, use lambda params
dotnet_diagnostic.MA0106.severity = suggestion      # Avoid closure via factory overload
dotnet_diagnostic.MA0112.severity = suggestion      # Count > 0 instead of Any()
dotnet_diagnostic.MA0159.severity = suggestion      # Use Order() instead of OrderBy(x => x)
dotnet_diagnostic.MA0160.severity = suggestion      # ContainsKey instead of TryGetValue
dotnet_diagnostic.MA0176.severity = suggestion      # Optimize Guid creation
dotnet_diagnostic.MA0178.severity = suggestion      # TimeSpan.Zero instead of FromXXX(0)

# Design — suggestion
dotnet_diagnostic.MA0003.severity = none            # Add parameter name (too noisy)
dotnet_diagnostic.MA0008.severity = suggestion      # Add StructLayoutAttribute
dotnet_diagnostic.MA0013.severity = warning         # Do not extend ApplicationException
dotnet_diagnostic.MA0014.severity = warning         # Do not raise ApplicationException
dotnet_diagnostic.MA0016.severity = suggestion      # Prefer collection abstraction
dotnet_diagnostic.MA0019.severity = suggestion      # Use EventArgs.Empty
dotnet_diagnostic.MA0025.severity = suggestion      # NotImplementedException in code
dotnet_diagnostic.MA0026.severity = suggestion      # Fix TODO comment
dotnet_diagnostic.MA0053.severity = none            # Make class sealed (too aggressive)
dotnet_diagnostic.MA0055.severity = warning         # Do not use finalizer
dotnet_diagnostic.MA0065.severity = warning         # Default struct Equals/HashCode
dotnet_diagnostic.MA0066.severity = warning         # Hash-unfriendly type as key
dotnet_diagnostic.MA0070.severity = suggestion      # Obsolete should include explanation
dotnet_diagnostic.MA0077.severity = suggestion      # Equals(T) should implement IEquatable<T>
dotnet_diagnostic.MA0094.severity = suggestion      # CompareTo(T) should implement IComparable<T>
dotnet_diagnostic.MA0099.severity = suggestion      # Use explicit enum value instead of 0
dotnet_diagnostic.MA0103.severity = suggestion      # Use SequenceEqual not ==
dotnet_diagnostic.MA0104.severity = suggestion      # Type name clashes with BCL
dotnet_diagnostic.MA0109.severity = none            # Consider Span<T>/Memory<T> overload (too noisy)
dotnet_diagnostic.MA0137.severity = none            # Async suffix (noisy with SK patterns)
dotnet_diagnostic.MA0138.severity = none            # Non-async without Async suffix
dotnet_diagnostic.MA0168.severity = suggestion      # Readonly struct for in/ref readonly

# Logging — suggestion
dotnet_diagnostic.MA0124.severity = suggestion      # Invalid log parameter type
dotnet_diagnostic.MA0125.severity = suggestion      # Invalid type in log parameter list
dotnet_diagnostic.MA0126.severity = warning         # Duplicate log parameter type
dotnet_diagnostic.MA0135.severity = suggestion      # Log parameter has no configured type
dotnet_diagnostic.MA0180.severity = suggestion      # ILogger<T> type should match containing type
dotnet_diagnostic.MA0183.severity = suggestion      # Format string should use placeholders

# xUnit rules
dotnet_diagnostic.xUnit1004.severity = suggestion   # Test methods should not be skipped

# EF Core Migrations (generated code - disable most analyzers)
[**/Migrations/*.cs]
generated_code = true
dotnet_diagnostic.CA1707.severity = none            # Underscores in identifiers (migration names)
dotnet_diagnostic.IDE0055.severity = none           # Formatting (generated code)
dotnet_diagnostic.IDE0005.severity = none           # Unnecessary usings

# Program.cs and startup utilities (sync calls are intentional at boot)
[**/Program.cs]
dotnet_diagnostic.CA1849.severity = none            # Sync methods in top-level statements are OK
dotnet_diagnostic.MA0042.severity = none            # Blocking calls OK in startup
dotnet_diagnostic.MA0045.severity = none            # Sync IO OK in startup

[**/DotEnv.cs]
dotnet_diagnostic.MA0045.severity = none            # Sync IO — runs once at boot before async pipeline

# Test files
[{Tests,*Tests,*.Tests}/**/*.cs]
dotnet_diagnostic.CA1707.severity = none            # Underscores in test method names
dotnet_diagnostic.MA0045.severity = none            # Sync calls OK in test setup/helpers

# JSON files
[*.json]
indent_size = 2
indent_style = space

# XML and config files
[*.{xml,csproj,props,targets,ruleset,config,nuspec,resx,vsixmanifest,vsct}]
indent_size = 2
indent_style = space

# YAML files
[*.{yml,yaml}]
indent_size = 2
indent_style = space

# Markdown files
[*.md]
trim_trailing_whitespace = false

# Shell scripts
[*.sh]
end_of_line = lf

# Windows batch files
[*.{cmd,bat}]
end_of_line = crlf

# Solution files
[*.sln]
indent_style = tab
