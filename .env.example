# App
ASPNETCORE_URLS=http://+:3010
LIS_EXEC_HOST=false                        # true = exec commands run on host via nsenter (requires pid:host + privileged)

# Database
DATABASE_URL=Host=postgres;Database=lis;Username=lis;Password=changeme

# AI Provider (Anthropic)
ANTHROPIC_ENABLED=true
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-20250514
ANTHROPIC_MAX_TOKENS=4096
ANTHROPIC_CONTEXT_BUDGET=12000
ANTHROPIC_THINKING_EFFORT=
ANTHROPIC_CACHE_ENABLED=true
ANTHROPIC_CACHE_TTL=5m

# AI Provider (OpenAI Codex) — optional, can run alongside Anthropic
CODEX_ENABLED=false
CODEX_ACCESS_TOKEN=eyJ...
CODEX_REFRESH_TOKEN=rt-...
CODEX_MODEL=gpt-5.5
CODEX_MAX_TOKENS=16384
CODEX_CONTEXT_BUDGET=100000
CODEX_REASONING_EFFORT=medium
CODEX_TRANSPORT=auto
CODEX_BASE_URL=https://chatgpt.com/backend-api

# Memories Embedding (optional — enables vector search for memories)
MEMORIES_EMBEDDING_ENABLED=false
MEMORIES_EMBEDDING_PROVIDER=openai
MEMORIES_EMBEDDING_MODEL=text-embedding-3-small
MEMORIES_EMBEDDING_API_KEY=sk-...
MEMORIES_EMBEDDING_BASE_URL=

# Channel (WhatsApp / GOWA)
GOWA_ENABLED=true
GOWA_BASE_URL=http://gowa:3000
GOWA_DEVICE_ID=default
GOWA_BASIC_AUTH=
GOWA_WEBHOOK_SECRET=changeme

# Channel (Telegram) — optional
TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=
TELEGRAM_WEBHOOK_URL=

# Channel (Discord) — optional
DISCORD_ENABLED=false
DISCORD_BOT_TOKEN=
DISCORD_APPLICATION_ID=

# Channel (Mattermost) — optional
MATTERMOST_ENABLED=false
MATTERMOST_URL=
MATTERMOST_BOT_TOKEN=
MATTERMOST_BOT_USER_ID=

# Lis
LIS_OWNER_JID=5511999999999@s.whatsapp.net
LIS_TIMEZONE=E. South America Standard Time
LIS_MESSAGE_DEBOUNCE_MS=3000
LIS_REACT_ON_MESSAGE_QUEUED=false
LIS_REACT_ON_MESSAGE_QUEUED_EMOJI=🕐
LIS_TOOL_NOTIFICATIONS=true
LIS_MAX_TOOL_ITERATIONS=10

# Context Compaction (0 or empty = percentage of ANTHROPIC_CONTEXT_BUDGET)
LIS_KEEP_RECENT_TOKENS=4000
LIS_TOOL_PRUNE_THRESHOLD=8000
LIS_TOOL_KEEP_THRESHOLD=2000
LIS_COMPACTION_THRESHOLD=                   # empty = 80% of context budget
LIS_COMPACTION_NOTIFY=true
LIS_TOOL_SUMMARIZATION_POLICY=auto

# Resume
LIS_RESUME_TOKEN_BUDGET=                    # empty = 70% of context budget

# OpenTelemetry (metrics, traces, logs → Grafana stack)
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_EXPORTER_OTLP_PROTOCOL=grpc

# Opik LLM Observability (optional)
OPIK_ENABLED=false
OPIK_BASE_URL=https://www.comet.com/opik
OPIK_API_KEY=
OPIK_WORKSPACE=default
OPIK_PROJECT=lis

# Compaction Client (optional — separate provider for summarization)
LIS_COMPACTION_PROVIDER=
LIS_COMPACTION_API_KEY=
LIS_COMPACTION_MODEL=
